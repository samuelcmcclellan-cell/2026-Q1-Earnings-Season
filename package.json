{
  "name": "earnings-tracker",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w server && npm run build -w client",
    "seed": "npm run seed -w server",
    "ingest": "node --experimental-transform-types scripts/ingest-csv.ts",
    "refresh": "node --experimental-transform-types scripts/refresh-data.ts",
    "validate-seed": "node scripts/validate-seed.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "esbuild-wasm": "^0.28.0"
  }
}
